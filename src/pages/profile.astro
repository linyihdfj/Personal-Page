---
import Layout from "../layouts/Layout.astro";
import profileData from "../data/profile.json";
---

<Layout title="Profile | Personal Blog">
  <section class="hero card">
    <img src={profileData.avatar} alt={`${profileData.name} avatar`} class="avatar" />
    <div>
      <p class="eyebrow">Profile</p>
      <h1>{profileData.name}</h1>
      <p class="lead">{profileData.school.degree}</p>
      <p class="muted">{profileData.school.university} · {profileData.school.lab}</p>
      <p class="muted">{profileData.school.focus}</p>
    </div>
  </section>

  <section class="card section">
    <h2>School Information</h2>
    <ul>
      <li><strong>Degree:</strong> {profileData.school.degree}</li>
      <li><strong>University:</strong> {profileData.school.university}</li>
      <li><strong>Lab:</strong> {profileData.school.lab}</li>
      <li><strong>Research Focus:</strong> {profileData.school.focus}</li>
    </ul>
  </section>

  <section class="card section">
    <h2>Awards</h2>
    <div class="stack">
      {
        profileData.awards.map((item) => (
          <article class="item">
            <div class="item-head">
              <h3>{item.title}</h3>
              <span>{item.year}</span>
            </div>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card section">
    <h2>Research Experience</h2>
    <div class="stack">
      {
        profileData.researchExperiences.map((exp) => (
          <article class="item">
            <div class="item-head">
              <h3>{exp.role}</h3>
              <span>{exp.period}</span>
            </div>
            <p class="muted">{exp.organization}</p>
            <p>{exp.details}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card section">
    <h2>Publications</h2>
    <ol class="pub-list">
      {
        profileData.publications.map((pub) => (
          <li>
            <span class="year">[{pub.year}]</span> {pub.citation}
          </li>
        ))
      }
    </ol>
  </section>
</Layout>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 10px 28px rgba(16, 37, 61, 0.05);
  }

  .hero {
    padding: 1.2rem;
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    align-items: center;
  }

  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 18px;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .eyebrow {
    margin: 0;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  h1 {
    margin: 0.25rem 0 0.4rem;
    font-size: clamp(1.45rem, 2.2vw, 2rem);
  }

  .lead {
    margin: 0;
    color: var(--primary);
    font-weight: 600;
  }

  .muted {
    color: var(--muted);
  }

  .section {
    margin-top: 1rem;
    padding: 1rem 1.2rem;
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  ul {
    margin: 0.8rem 0 0;
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .item {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.75rem 0.85rem;
    background: #fff;
  }

  .item-head {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    align-items: baseline;
  }

  .item h3 {
    margin: 0;
    font-size: 1rem;
  }

  .item p {
    margin: 0.35rem 0 0;
    line-height: 1.7;
  }

  .pub-list {
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .year {
    color: var(--primary);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
  }
</style>
