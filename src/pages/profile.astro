---
import Layout from "../layouts/Layout.astro";
import rawProfileData from "../data/profile.json";

type Award = { year: string; title: string };
type ResearchExperience = {
  role: string;
  period: string;
  organization: string;
  details: string;
};
type Publication = { year: string; citation: string };
type ProfileData = {
  avatar: string;
  name: string;
  school: {
    degree: string;
    university: string;
    focus: string;
  };
  awards: Award[];
  researchExperiences: ResearchExperience[];
  publications: Publication[];
};

const profileData = rawProfileData as ProfileData;

const avatarUrl = /^https?:\/\//i.test(profileData.avatar)
  ? profileData.avatar
  : `${import.meta.env.BASE_URL}${profileData.avatar.replace(/^\//, "")}`;
---

<Layout title="Profile | Personal Blog">
  <section class="hero card">
    <img src={avatarUrl} alt={`${profileData.name} avatar`} class="avatar" />
    <div>
      <!-- <p class="eyebrow">Profile</p> -->
      <h1>{profileData.name}</h1>
      <ul class="hero-info">
        <li><strong>学位:</strong> {profileData.school.degree}</li>
        <li><strong>学校:</strong> {profileData.school.university}</li>
        <li><strong>研究方向:</strong> {profileData.school.focus}</li>
      </ul>
    </div>
  </section>

  <section class="card section">
    <h2>所获奖项</h2>
    <div class="stack">
      {
        profileData.awards.map((item) => (
          <article class="item">
            <div class="item-head">
              <h3>{item.title}</h3>
              <span>{item.year}</span>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card section">
    <h2>科研经历</h2>
    <div class="stack">
      {
        profileData.researchExperiences.map((exp) => (
          <article class="item">
            <div class="item-head">
              <h3>{exp.role}</h3>
              <span>{exp.period}</span>
            </div>
            <p class="muted">{exp.organization}</p>
            <p>{exp.details}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card section">
    <h2>发表论文</h2>
    <ol class="pub-list">
      {
        profileData.publications.map((pub) => (
          <li>
            <span class="year">[{pub.year}]</span> {pub.citation}
          </li>
        ))
      }
    </ol>
  </section>
</Layout>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 10px 28px rgba(16, 37, 61, 0.05);
  }

  .hero {
    padding: 1.2rem;
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    align-items: center;
  }

  .avatar {
    width: 140px;
    height: 140px;
    border-radius: 18px;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .eyebrow {
    margin: 0;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  h1 {
    margin: 0.25rem 0 0.4rem;
    font-size: clamp(1.45rem, 2.2vw, 2rem);
  }

  .muted {
    color: var(--muted);
  }

  .hero-info {
    margin: 0.55rem 0 0;
    padding-left: 1.1rem;
    line-height: 1.8;
  }

  .hero-info li {
    color: var(--muted);
  }

  .hero-info strong {
    color: var(--text);
  }

  .section {
    margin-top: 1rem;
    padding: 1rem 1.2rem;
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .stack {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .item {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.75rem 0.85rem;
    background: #fff;
  }

  .item-head {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    align-items: baseline;
  }

  .item h3 {
    margin: 0;
    font-size: 1rem;
  }

  .item p {
    margin: 0.35rem 0 0;
    line-height: 1.7;
  }

  .pub-list {
    margin: 0.9rem 0 0;
    padding-left: 1.2rem;
    line-height: 1.8;
  }

  .year {
    color: var(--primary);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
  }
</style>
