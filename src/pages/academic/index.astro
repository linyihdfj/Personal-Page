---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

type NoteItem = {
  slug: string;
  data: {
    title: string;
    date: Date;
    summary: string;
    tags: string[];
  };
};

function toPathSlug(id: string) {
  return id.replace(/\.(md|mdx)$/i, "");
}

let notes: NoteItem[] = [];

const fromCollection = await getCollection("academic");
notes = fromCollection.map((note) => ({
  slug: toPathSlug(note.id),
  data: {
    title: note.data.title,
    date: note.data.date,
    summary: note.data.summary,
    tags: note.data.tags,
  },
}));

notes = notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Academic | Personal Blog">
  <section class="hero card">
    <p class="eyebrow">Academic</p>
    <h1>Paper Reading Notes</h1>
    <p>
      Notes are organized as reading collections. Each note can contain multiple papers with links,
      figures, core ideas, abstracts and recommendation ratings.
    </p>
  </section>

  {notes.length === 0 ? (
    <section class="card empty-state">
      <h2>No Academic Notes Found</h2>
      <p>
        未读取到 `src/content/academic` 下的有效 Markdown。请确认 frontmatter 包含
        title/date/summary/tags，并重启 dev server。
      </p>
    </section>
  ) : (
    <section class="notes-grid">
      {
        notes.map((note) => (
          <article class="card note-card">
            <h2>
              <a href={`/academic/${note.slug}`}>{note.data.title}</a>
            </h2>
            <p class="meta">{note.data.date.toISOString().slice(0, 10)} · {note.data.tags.join(" / ")}</p>
            <p>{note.data.summary}</p>
            <a href={`/academic/${note.slug}`} class="read-more">Read Note</a>
          </article>
        ))
      }
    </section>
  )}
</Layout>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 10px 28px rgba(16, 37, 61, 0.05);
  }

  .hero {
    padding: 1.2rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--muted);
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  h1 {
    margin: 0.2rem 0 0.55rem;
    font-size: clamp(1.5rem, 2.3vw, 2rem);
  }

  .hero p {
    margin: 0;
    line-height: 1.7;
    color: var(--muted);
  }

  .notes-grid {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.9rem;
  }

  .note-card {
    padding: 1rem;
  }

  .empty-state {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
  }

  .empty-state h2 {
    margin: 0;
  }

  .empty-state p {
    margin: 0.5rem 0 0;
    color: var(--muted);
    line-height: 1.75;
  }

  h2 {
    margin: 0;
    font-size: 1.08rem;
  }

  h2 a {
    color: var(--text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--primary);
  }

  .meta {
    margin: 0.45rem 0 0.55rem;
    color: var(--muted);
    font-size: 0.93rem;
  }

  .note-card p {
    margin: 0;
    line-height: 1.65;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
  }
</style>
