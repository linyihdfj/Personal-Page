---
const pathname = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL;

const normalizePath = (path: string) => {
  if (path.length > 1 && path.endsWith("/")) return path.slice(0, -1);
  return path;
};

const links = [
  { href: `${baseUrl}profile/`, label: "Profile" },
  { href: `${baseUrl}academic/`, label: "Academic" },
];
---

<header class="nav-wrap">
  <nav class="nav">
    {
      links.map((item) => {
        const currentPath = normalizePath(pathname);
        const targetPath = normalizePath(item.href);
        const active = currentPath === targetPath || currentPath.startsWith(`${targetPath}/`);
        return (
          <a href={item.href} class={`nav-link ${active ? "active" : ""}`}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    width: min(1080px, 92vw);
    margin: 0 auto;
    display: flex;
    gap: 0.75rem;
    padding: 0.9rem 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: all 180ms ease;
  }

  .nav-link:hover {
    color: var(--primary);
    border-color: var(--line);
    background: var(--surface);
  }

  .nav-link.active {
    color: var(--primary);
    background: var(--primary-soft);
    border-color: color-mix(in srgb, var(--primary) 25%, var(--line));
  }

  @media (max-width: 720px) {
    .nav {
      width: min(1080px, 94vw);
      justify-content: center;
    }
  }
</style>
