---
interface Paper {
  paperIndex: number;
  paperTitle: string;
  arxivUrl?: string;
  hallucinationTranslationUrl?: string;
  images: string[];
  imageModes: Array<"local" | "remote">;
  coreIdea: string;
  abstract: string;
  rating?: number;
  warnings: string[];
}

const { paper } = Astro.props as { paper: Paper };

const hasRating = typeof paper.rating === "number";
const safeRating = hasRating ? Math.max(0, Math.min(5, paper.rating as number)) : 0;
const fullStars = Math.floor(safeRating);
const hasHalf = safeRating - fullStars >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---

<article class="paper-card">
  {paper.warnings.length > 0 && (
    <div class="paper-warnings" role="status" aria-live="polite">
      <p>Paper #{paper.paperIndex} 存在字段警告：</p>
      <ul>
        {paper.warnings.map((warning) => (
          <li>{warning}</li>
        ))}
      </ul>
    </div>
  )}

  <div class="paper-header">
    <h3>{paper.paperTitle}</h3>
    <div class="paper-links">
      {paper.arxivUrl ? (
        <a href={paper.arxivUrl} target="_blank" rel="noreferrer" class="paper-link">ArXiv</a>
      ) : (
        <span class="paper-link disabled" aria-disabled="true">ArXiv Missing</span>
      )}

      {paper.hallucinationTranslationUrl ? (
        <a
          href={paper.hallucinationTranslationUrl}
          target="_blank"
          rel="noreferrer"
          class="paper-link"
        >
          幻觉翻译
        </a>
      ) : (
        <span class="paper-link disabled" aria-disabled="true">幻觉翻译 Missing</span>
      )}
    </div>
  </div>

  {paper.images.length > 0 && (
    <div class="paper-images">
      {paper.images.map((src, idx) => (
        <figure class="img-wrap">
          <img src={src} alt={`${paper.paperTitle} figure ${idx + 1}`} loading="lazy" />
          <figcaption>{paper.imageModes[idx] === "remote" ? "remote" : "local"}</figcaption>
        </figure>
      ))}
    </div>
  )}

  <div class="paper-body">
    <section>
      <h4>Core Idea</h4>
      <p>{paper.coreIdea}</p>
    </section>

    <section>
      <h4>Abstract</h4>
      <p>{paper.abstract}</p>
    </section>

    <section>
      <h4>Recommendation</h4>
      {hasRating ? (
        <div class="rating" aria-label={`Rating ${safeRating} out of 5`}>
          {Array.from({ length: fullStars }).map(() => (
            <span class="star full">★</span>
          ))}
          {hasHalf && <span class="star half">★</span>}
          {Array.from({ length: emptyStars }).map(() => (
            <span class="star empty">★</span>
          ))}
          <span class="score">{safeRating.toFixed(1)}/5</span>
        </div>
      ) : (
        <p class="score missing">未评分</p>
      )}
    </section>
  </div>
</article>

<style>
  .paper-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 1.15rem;
    box-shadow: 0 10px 30px rgba(16, 37, 61, 0.05);
  }

  .paper-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem;
    align-items: center;
  }

  .paper-header h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .paper-warnings {
    margin-bottom: 0.9rem;
    border: 1px solid #f2c979;
    background: #fff7e5;
    border-radius: 12px;
    padding: 0.7rem 0.8rem;
  }

  .paper-warnings p {
    margin: 0;
    color: #7a4c0f;
    font-weight: 700;
    font-size: 0.92rem;
  }

  .paper-warnings ul {
    margin: 0.45rem 0 0;
    padding-left: 1.1rem;
    color: #7a4c0f;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .paper-link {
    text-decoration: none;
    color: var(--primary);
    font-weight: 600;
    border-bottom: 1px dashed color-mix(in srgb, var(--primary) 50%, white);
  }

  .paper-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
  }

  .paper-link.disabled {
    color: #8a97a3;
    border-bottom: 1px dashed #b6c2cc;
  }

  .paper-images {
    margin-top: 0.9rem;
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .img-wrap {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #fff;
  }

  .img-wrap figcaption {
    padding: 0.3rem 0.5rem 0.4rem;
    font-size: 0.78rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .img-wrap img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .paper-body {
    margin-top: 1rem;
    display: grid;
    gap: 0.9rem;
  }

  .paper-body h4 {
    margin: 0 0 0.45rem;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .paper-body p {
    margin: 0;
    line-height: 1.7;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .star {
    font-size: 1.1rem;
    line-height: 1;
  }

  .star.full {
    color: #e2ad28;
  }

  .star.half {
    background: linear-gradient(90deg, #e2ad28 50%, #cfd8e0 50%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .star.empty {
    color: #cfd8e0;
  }

  .score {
    margin-left: 0.45rem;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .score.missing {
    margin: 0;
    color: #8a97a3;
  }
</style>
