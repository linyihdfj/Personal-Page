---
import Navigation from "../components/Navigation.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Personal blog with profile and academic notes" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-bg"></div>
    <Navigation />
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f7fafc;
    --bg-alt: #edf2f7;
    --surface: #ffffff;
    --text: #10253d;
    --muted: #526579;
    --line: #d8e3ec;
    --primary: #1f4f7c;
    --primary-soft: #e8f0f8;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  }

  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 80% -10%, #d9e8f5 0%, transparent 40%),
      radial-gradient(circle at 15% 110%, #dce9f3 0%, transparent 35%),
      linear-gradient(180deg, var(--bg), var(--bg-alt));
  }

  .container {
    width: min(1080px, 92vw);
    margin: 2rem auto 3rem;
  }

  @media (max-width: 720px) {
    .container {
      width: min(1080px, 94vw);
      margin-top: 1.2rem;
    }
  }
</style>
